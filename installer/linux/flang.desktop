[Desktop Entry]
# =============================================================================
# Flang - Linux Desktop Integration File
# Arquivo de Integracao com o Desktop Linux
#
# Instale em / Install to:
#   Sistema / System:  /usr/share/applications/flang.desktop
#   Usuario / User:    ~/.local/share/applications/flang.desktop
#
# Apos instalar, execute / After installing, run:
#   update-desktop-database ~/.local/share/applications
# =============================================================================

Version=1.0
Type=Application

# Nome do aplicativo / Application name
Name=Flang
Name[pt_BR]=Flang
Name[en]=Flang

# Descricao / Description
Comment=Linguagem de programacao declarativa full-stack
Comment[pt_BR]=Linguagem de programacao declarativa full-stack
Comment[en]=Declarative full-stack programming language

# Icone (usa o icone generico de codigo se o proprio nao existir)
# Icon (uses generic code icon if own icon doesn't exist)
Icon=text-x-script

# Comando para executar arquivos .fg / Command to run .fg files
# %f = arquivo selecionado / selected file
Exec=bash -c 'flang run "%f"; read -p "Pressione Enter para fechar..."'

# Tambem suporta multiplos arquivos / Also supports multiple files
# Exec=bash -c 'for f in %F; do flang run "$f"; done; read -p "Enter para fechar..."'

# Categorias do menu / Menu categories
Categories=Development;IDE;TextEditor;

# Tipos MIME suportados / Supported MIME types
# Associa arquivos .fg ao Flang / Associates .fg files with Flang
MimeType=text/x-flang;application/x-flang;

# Palavras-chave para busca / Keywords for search
Keywords=programming;language;flang;fg;code;declarative;backend;api;

# Nao exibe no menu de aplicativos por padrao (e uma ferramenta CLI)
# Not shown in app menu by default (it's a CLI tool)
# Remova/comente a linha abaixo para aparecer no menu
# Remove/comment the line below to show in menu
# NoDisplay=true

# Inicia em terminal / Starts in terminal
Terminal=true

# Aplicativo suporta startup notification
StartupNotify=false

# Versao minima do sistema de desktop / Minimum desktop system version
# X-GNOME-UsesNotifications=false
